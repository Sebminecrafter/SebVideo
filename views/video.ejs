<%
name = details.name;
author = details.author;
videourl = details.src;
page = name;
%>
<%- include('partials/header') %>

<div class="video">
    <video src="<%= videourl %>" controls></video>
    <h1><%= name %></h1>
    <h3><%= author %></h3>
</div>
<div class="riverview">
    <% for( let index = 0; index < recommended.length; index++ ) { %>
    <% video = recommended[index] %>
    <%- include('partials/recommendedvideo') %>
    <% } %>
</div>

<%- include('partials/footer') %>