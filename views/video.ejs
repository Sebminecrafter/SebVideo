<%
name = details.name;
author = details.author;
description = details.description;
page = name;
videourl = "/api/getVideo?id=" + details.id;
thumbnail = "/api/thumbnail?id=" + details.id;
views = 1;
var date = new Date(details.date);
uploadDate = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
max = 30;
%>
<%- include('partials/header') %>

<div class="video">
    <% if (details.processing) { %>
        <div class="video-placeholder">
            <div class="placeholder-content">
                <div class="spinner"></div>
                <p>Video is being processed...</p>
                <p style="font-size: 0.9em; opacity: 0.7;">This may take a few moments. Please check back soon.</p>
            </div>
        </div>
    <% } else { %>
        <video src="<%- videourl %>" poster="<%- thumbnail %>" preload="auto" controls></video>
    <% } %>
    <div class="videobar">
        <h1 id="title"><%= name %></h1>
        <% if (!details.processing) { %>
            <a id="download" href="<%- videourl %>" download="<%= name %>.mp4">Download</a>
        <% } else { %>
            <button id="download" disabled style="opacity: 0.5; cursor: not-allowed;">Download (Processing)</button>
        <% } %>
    </div>
    <div class="channelbar">
        <img id="icon" src="" alt="Channel Logo">
        <h3 id="name"><%= author %></h3>
    </div>
    <details class="description">
        <summary>
            <%= views.toLocaleString() %> view<% if (views != 1) { %>s<% } %>
            <strong><%= uploadDate %></strong>
            <div class="preview"><%= description.slice(0, max) %>&hellip;</div>
            <span class="toggle">
                <span class="label-more">Show more</span>
                <span class="label-less">Show less</span>
            </span>
        </summary>
        <p><%= description %></p>
    </details>
</div>
<div class="riverview">
    <% for( let index = 0; index < recommended.length; index++ ) { %>
    <% video = recommended[index] %>
    <%- include('partials/videodisplay') %>
    <% } %>
</div>

<%- include('partials/footer') %>